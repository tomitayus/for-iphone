# === AI API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AI...
XAI_API_KEY=xai-...

# === Notification Settings ===
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFY_EMAIL=you@gmail.com

# Webhook (Slack, Discord, IFTTT, etc.)
WEBHOOK_URL=

# === Output Settings ===
# Where to save generated HTML diagrams
OUTPUT_DIR=./output

# Public base URL if hosted (e.g., GitHub Pages, Netlify)
PUBLIC_BASE_URL=
